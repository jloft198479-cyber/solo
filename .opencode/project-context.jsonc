  "keyDecisions": {
    // ── v1.2.5: 多进程独立架构 ──
    "multiProcessInsteadOfSingleInstance": "tauri-plugin-single-instance 导致全进程卡死（LevelDB 锁竞争 + 主线程同步阻塞）。拆除改多进程：每个 .md 双击启动独立 solo.exe，独立 WebView2 数据目录（%TEMP%），互不牵连。Settings 用 tauri-plugin-store JSON + 文件锁，多进程安全。见 PROFILE.md §全进程卡死根因修复",

    // ── 窗口/生命周期 ──
    "onWindowEventSingleCallback": "Tauri v2 只支持一个回调→必须合并",
    "saveCurrentDocumentWait": "isSaving 锁改为等待≤1s 而非直接 false",
    "exitAppViaRustCommand": "app.exit(0) 通过 IPC 调用，不在主线程",

    // ── 文件关联 ──
    "installerHooksForFileAssoc": "Tauri fileAssociations 不写 ShellNew/DefaultIcon；Rust 运行时注册太晚。NSIS 安装阶段写注册表 + SHChangeNotify 刷新，装完即生效。见 PROFILE.md §文件关联",

    // ── Markdown roundtrip ──
    "serializerEscapeTwoModes": "clipboard=false（文件保存）严格转义 14 字符（移除 !?）保证 fidelity；clipboard=true（剪贴板）仅转义 \\ ` * + 行首特殊字符。见 serializer.ts:136-150",
    "nestedListIndentDepth": "每级嵌套 3 空格缩进（CommonMark 标准）。serializer.ts listDepth 计数",
    "taskListDetection": "parser bullet_list_open 前看 token 检测 task-list-item class → 开 taskList 代替 bulletList；checked 状态从 html_inline <input checked=\"\"> 提取，不从 class 属性（markdown-it-task-lists 仅 token 阶段不加 checked class）",
    "cjkBoldBoundaryZWNJ": "CJK 标点后 **/* 边界问题同根因：CommonMark scanDelims 以 Unicode 类别判定 right_flanking。Po/S 类使 canClose=false。serializer 为 bold 和 italic 插入 ZWNJ (Cf 类) 使 parser 正确识别关闭符，零副作用。纯 markdown roundtrip（不经编辑）退化为转义，这是规范限制。见 PROFILE.md §CJK 标点加粗边界",

    // ── v1.2.10: 字体缓存 ──
    "fontCacheFileSystemNotIndexedDB": "多进程架构下，IndexedDB 绑定在 WebView2 数据目录（每进程独立），跨进程不共享。改用 app_local_data_dir/font-cache/ 文件目录，所有进程读写同一路径。写时 temp file + rename 防并发脏读。见 PROFILE.md §字体缓存架构",
  },

