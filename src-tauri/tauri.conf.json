{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solo",
  "version": "1.2.29",
  "identifier": "com.solomarkdown",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "未命名",
        "width": 1200,
        "height": 800,
        "minWidth": 320,
        "minHeight": 240,
        "center": true,
        "visible": false,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https: http:; font-src 'self' data: blob: https: http:; connect-src ipc: http://ipc.localhost https: http:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/font-cache/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "contentTypes": ["net.daringfireball.markdown", "public.plain-text", "public.text"],
        "name": "solo文档",
        "description": "solo文档",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerHooks": "./nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDRTg1Njg3MDZGNkZFMjAKUldRZy92WUdoMWJvTEM0cnhjcklJbUxXc0lXSEJ2UXVoZlF0cHVoYkFkRTRQOVkrSk9pSEFjMWYK",
      "endpoints": [
        "https://github.com/jloft198479-cyber/solo/releases/latest/download/latest.json"
      ]
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "cli": {
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Markdown file to open"
        }
      ]
    }
  }
}
