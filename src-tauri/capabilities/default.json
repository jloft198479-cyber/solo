{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for all editor windows",
  "windows": ["main", "editor-*"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "clipboard-manager:default",
    "store:default",
    "window-state:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
